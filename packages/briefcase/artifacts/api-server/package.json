{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "seed": "tsx scripts/seed-demo-user.ts",
    "db:bootstrap": "tsx scripts/bootstrap-db.ts",
    "db:smoke": "tsx scripts/db-smoke.ts",
    "check:providers": "tsx scripts/check-providers.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:g3": "tsx scripts/g3-contract-smoke.ts",
    "smoke:g7": "tsx scripts/g7-defender-smoke.ts",
    "smoke:g22": "tsx scripts/g22-audit-bundle-smoke.ts",
    "seed:state-v-johnson": "tsx scripts/seed-state-v-johnson.ts",
    "demo:reset": "tsx scripts/demo-reset.ts",
    "replay": "tsx scripts/replay.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@e2b/code-interpreter": "^2.4.2",
    "@opentelemetry/api": "^1.9.1",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "ai": "^5.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "fflate": "^0.8.2",
    "multer": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pino": "^9",
    "pino-http": "^10",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/multer": "^1.4.13",
    "@types/node": "catalog:",
    "@types/pdf-parse": "^1.1.5",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "tsx": "catalog:"
  }
